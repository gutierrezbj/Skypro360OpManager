# OpsManager — Production Environment Variables
# Copy to .env.production and fill with real values

# App
NODE_ENV=production

# Database (PostgreSQL + PostGIS)
DB_USER=opsmanager
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=opsmanager
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@opsmanager-db:5432/${DB_NAME}

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@opsmanager-redis:6379/0

# Auth (generate: openssl rand -base64 32)
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
AUTH_URL=https://skp360mgr.systemrapid.io
AUTH_TRUST_HOST=true

# Public URLs
NEXT_PUBLIC_APP_URL=https://skp360mgr.systemrapid.io
NEXT_PUBLIC_MAPLIBRE_STYLE=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json

# Optional: SMTP for notifications
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
