# OpsManager — Environment Variables
# Copy to .env.local and fill in values

# App
NODE_ENV=development
PORT=3100

# Database (PostgreSQL + PostGIS) — offset +100
DATABASE_URL=postgresql://opsmanager:opsmanager@localhost:6100/opsmanager

# Redis — offset +100
REDIS_URL=redis://localhost:6101/0

# Auth (Auth.js) — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3100

# MapLibre (public)
NEXT_PUBLIC_APP_URL=http://localhost:3100
NEXT_PUBLIC_MAPLIBRE_STYLE=https://demotiles.maplibre.org/style.json

# Optional: SMTP for notifications
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
